# ─────────────────────────────────────────────
# Configuração do Banco de Dados
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=api_academica
DB_USER=root
DB_PASS=

# ─────────────────────────────────────────────
# Configuração do JWT
#
# JWT_SECRET: chave secreta para assinar os tokens
#   IMPORTANTE: troque por algo longo e aleatório em produção!
#   Exemplo: use um gerador de senhas com 64+ caracteres
#
# JWT_ACCESS_EXPIRY: duração do access token em segundos
#   900 = 15 minutos (recomendado)
#
# JWT_REFRESH_EXPIRY: duração do refresh token em segundos
#   604800 = 7 dias
# ─────────────────────────────────────────────
JWT_SECRET=troque_esta_chave_por_uma_string_longa_e_aleatoria_em_producao
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# ─────────────────────────────────────────────
# Ambiente da Aplicação
# ─────────────────────────────────────────────
APP_ENV=development
